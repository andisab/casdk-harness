# =============================================================================
# Claude Agent SDK Harness - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# =============================================================================
# Required Configuration
# =============================================================================

# Anthropic API Key (Required)
ANTHROPIC_API_KEY=sk-ant-your_api_key_here


# =============================================================================
# CLI Authentication (NOT MCP - used by gh and glab commands)
# =============================================================================
# These are for the GitHub CLI (gh) and GitLab CLI (glab), not MCP servers.
# Alternatively, run `gh auth login` or `glab auth login` inside the container.

# GitHub CLI: Set GITHUB_PERSONAL_ACCESS_TOKEN or run `gh auth login`
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# GitLab CLI: Set GITLAB_PERSONAL_ACCESS_TOKEN or run `glab auth login`
# GITLAB_PERSONAL_ACCESS_TOKEN=glpat-your_token_here


# =============================================================================
# MCP Server API Keys
# =============================================================================
# Copy this file to .env.mcp and fill in your values.
# This file is loaded automatically by docker-compose.yml via the env_file directive.
# Add new MCP server credentials here without modifying docker-compose.yml.

# =============================================================================
# Agent Configuration
# =============================================================================

# Claude Model Selection
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Permission Mode for Interactive Mode (see AUTONOMOUS_PERMISSION_MODE for autonomous)
# - default: Require approval for each action (safest)
# - acceptEdits: Auto-approve file edits, prompt for other actions (recommended)
# - bypassPermissions: Fully autonomous (use with caution)
CLAUDE_PERMISSION_MODE=acceptEdits

# Agent Behavior
CLAUDE_MAX_TURNS=1000
CLAUDE_SESSION_TIMEOUT=72000  # 20 hours in seconds
CLAUDE_CHECKPOINT_INTERVAL=3600  # 1 hour in seconds
CLAUDE_API_TIMEOUT=900  # 15 minutes inactivity timeout (resets on each message)
CLAUDE_AGENT_VERBOSE=true  # Show progress for subagent invocations (true/false)

# =============================================================================
# Infrastructure Configuration
# =============================================================================

# Docker BuildKit
DOCKER_BUILDKIT=1
BUILDKIT_PROGRESS=plain
COMPOSE_DOCKER_CLI_BUILD=1

# Project Configuration
COMPOSE_PROJECT_NAME=claude-harness
REGISTRY=ghcr.io/andisab/claudeagentsdk-harness
IMAGE_TAG=latest

# Environment: development | staging | production
ENVIRONMENT=development

# Platform (auto-detected for OrbStack)
# linux/amd64 | linux/arm64
PLATFORM=linux/arm64

# =============================================================================
# Resource Limits
# =============================================================================

# Main Agent Resources
AGENT_CPU_LIMIT=4
AGENT_MEMORY_LIMIT=8G
AGENT_CPU_RESERVATION=2
AGENT_MEMORY_RESERVATION=4G

# Agent Two Resources (Default: Evaluator)
AGENT_TWO_CPU_LIMIT=2
AGENT_TWO_MEMORY_LIMIT=4G

# Agent Three Resources (Default: Validator)
AGENT_THREE_CPU_LIMIT=2
AGENT_THREE_MEMORY_LIMIT=4G

# =============================================================================
# Autonomous Mode Configuration
# =============================================================================

# Delay between autonomous sessions (seconds)
# Note: Code default is 5 if not set
AUTONOMOUS_DELAY_SECONDS=3

# Maximum number of autonomous sessions before stopping
AUTONOMOUS_MAX_SESSIONS=100

# Timeout per task in seconds (default: 30 minutes)
AUTONOMOUS_TASK_TIMEOUT=1800

# Permission Mode for Autonomous Mode (separate from interactive CLAUDE_PERMISSION_MODE)
# - acceptEdits: Auto-approve file edits, prompt for other actions
# - bypassPermissions: Fully autonomous, no prompts (default for autonomous mode)
# - default: Require approval for each action
AUTONOMOUS_PERMISSION_MODE=bypassPermissions

# Bypass bash command security checks (DANGEROUS - use only for trusted workloads)
# BASH_ALLOW_ALL=false

# =============================================================================
# Monitoring & Observability
# =============================================================================

# Grafana Configuration
GRAFANA_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION
GRAFANA_PORT=3000

# Prometheus Configuration
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# AlertManager — receives Prometheus alerts and dispatches to receivers.
# The bundled `alertmanager-webhook` debug receiver logs every payload to stdout
# (visible via `docker compose logs alertmanager-webhook`). Replace with Slack,
# email, or PagerDuty config in config/monitoring/alertmanager.yml for production.
ALERTMANAGER_VERSION=v0.27.0
ALERTMANAGER_PORT=9093
ALERTMANAGER_WEBHOOK_PORT=9099

# OpenTelemetry Collector — bridges native OTLP signals from the Claude
# Agent SDK into Prometheus. The harness deliberately routes SDK telemetry
# to its own bundled collector (hardcoded in docker-compose.yml) so that
# host-level OTel env vars (e.g., a global Claude Code OTLP endpoint) do
# not leak into harness containers. To redirect telemetry to an external
# collector, edit the OTEL_* values in docker-compose.yml directly or use
# a docker-compose override file.
OTEL_COLLECTOR_VERSION=0.119.0
OTEL_GRPC_PORT=4317          # OTLP gRPC receiver (host-mapped)
OTEL_HTTP_PORT=4318          # OTLP HTTP receiver (host-mapped)
# Note: ports 8889 (SDK Prometheus exporter) and 8888 (collector self-metrics)
# are intentionally NOT host-mapped to avoid conflicts with host services
# (Jupyter often uses 8888). They are scraped by Prometheus over the docker
# network. Inspect via http://localhost:9090 (Prometheus UI) instead.

# Logging Configuration
# LOG_LEVEL controls verbosity of system logs (not chat output)
# - DEBUG: Everything including function calls, metrics, internal operations
# - INFO: Session events, agent actions, checkpoint saves (DEFAULT)
# - WARNING: Only warnings and errors (recommended for clean interactive chat)
# - ERROR: Only errors and critical failures
# - CRITICAL: Only catastrophic failures
#
# For interactive sessions: Use WARNING for cleaner output, or use --quiet flag
# For debugging: Use DEBUG or INFO
LOG_LEVEL=INFO

# LOG_FORMAT controls log output format
# - json: Structured JSON logs for production/parsing (recommended)
# - text: Human-readable text logs for development
LOG_FORMAT=json

# =============================================================================
# Cache Configuration (Optional)
# =============================================================================

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION

# =============================================================================
# Cloud Provider Configuration (Optional)
# =============================================================================

# AWS Bedrock (set to 1 to enable)
CLAUDE_CODE_USE_BEDROCK=0
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GCP Vertex AI (set to 1 to enable)
CLAUDE_CODE_USE_VERTEX=0
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=
GCP_REGION=us-central1

# =============================================================================
# Security Configuration
# =============================================================================

# Secret rotation interval (days)
SECRET_ROTATION_DAYS=30

# Session token settings
SESSION_SECRET=CHANGE_ME_BEFORE_PRODUCTION
SESSION_TIMEOUT=3600  # 1 hour

# Metrics endpoint authentication (optional - leave empty to disable auth)
# Format: username:password for basic auth
METRICS_AUTH_TOKEN=

# =============================================================================
# Multi-Agent Mode
# =============================================================================
# By default, only main-agent + monitoring (prometheus/grafana) start.
# Use `make dev-multi` or `make up-multi` to enable multi-agent services.
#
# Multi-agent includes:
#   - agent-two: Evaluator (read-only workspace access, default: code review)
#   - agent-three: Validator (full workspace access, default: testing)
#   - redis: Inter-agent communication (Redis Streams)
#
# To enable multi-agent mode:
#   - make dev-multi        (development with hot-reload)
#   - make up-multi         (background services)
#   - make down             (stops all services including multi-agent)
#
# Each agent loads its dedicated system prompt from src/harness/prompts/:
#   - main-agent: main-interactivedev-agent.md
#   - agent-two: agent-two.md
#   - agent-three: agent-three.md

# =============================================================================
# Plugin Configuration
# =============================================================================

# Comma-separated list of enabled plugins. Leave empty to enable all discovered.
#
# After running `make plugins-sync` (or rebuilding the Docker image), the
# harness discovers plugins from BOTH ./src/harness/plugins/ and the
# swe-marketplace clone (~12 marketplace plugins). Empty ENABLED_PLUGINS
# activates everything — set explicitly if you only want a subset.                                                                         
ENABLED_PLUGINS=research-team,context-engineering,cgf-agents

# -----------------------------------------------------------------------------
# swe-marketplace plugin source
# -----------------------------------------------------------------------------
# The harness consumes shared plugins (research-team, context-engineering, etc.)
# from a local clone of https://github.com/andisab/swe-marketplace.
#
# Populate the clone with `make plugins-sync` for local dev. The Dockerfile
# clones it automatically into the container at /opt/plugins/swe-marketplace.
#
# Auto-detection order (only used if SWE_MARKETPLACE_PATH is unset):
#   1. /opt/plugins/swe-marketplace      (container default)
#   2. <repo-root>/.plugins/swe-marketplace  (local dev, gitignored)
SWE_MARKETPLACE_PATH=

# Pin the marketplace clone to a specific git ref (tag, SHA, branch).
# Empty = HEAD of default branch. Recommend pinning to a known-good tag/SHA
# in CI for reproducibility; bump deliberately.
SWE_MARKETPLACE_REF=

# =============================================================================
# CGF (Context Gradient Feedback) Optimization
# =============================================================================
# Usage: make optimize AGENT=<agent-name>
# This starts a two-phase optimization session:
#   1. Q&A Phase: cgf-initializer agent gathers requirements interactively
#   2. Optimization Phase: cgf-orchestrator runs autonomous optimization

# -----------------------------------------------------------------------------
# Phase Timeouts (seconds)
# -----------------------------------------------------------------------------
# Each phase has a configurable timeout to handle long-running operations.
# Research phase is the longest because it may spawn multiple subagent researchers.

CGF_RESEARCH_TIMEOUT=1800    # 30 minutes for research phase
CGF_GENERATE_TIMEOUT=900     # 15 minutes per resource generation
CGF_ITERATE_TIMEOUT=600      # 10 minutes per optimization iteration
CGF_VALIDATE_TIMEOUT=300     # 5 minutes for validation phase

# -----------------------------------------------------------------------------
# Progress Display
# -----------------------------------------------------------------------------
# Control real-time output visibility during optimization.
# All default to true for maximum visibility. Set to false for quiet mode.

CGF_SHOW_PROGRESS=true       # Show phase transitions and progress updates
CGF_SHOW_STATUS=true         # Show status summary before/after optimization
CGF_FOLLOW_LOGS=true         # Stream agent activity in real-time

# -----------------------------------------------------------------------------
# Unified CGF Optimization Settings
# -----------------------------------------------------------------------------

# Optimizer mode: agentic (default)
# Uses LLM self-critique, no test suite required
CGF_OPTIMIZER_MODE=agentic

# Maximum optimization iterations the orchestrator agent should self-pace.
# This is the spec-level hint passed to the agent; it is NOT a hard cap.
# Use CGF_MAX_ITERATIONS for the hard Python-side ceiling.
CGF_ITERATIONS=10

# Hard Python-side cap on [ITERATION_COMPLETE] signals.  Default 3.  The
# runner refuses additional iterations beyond this and forces the agent
# to terminate with [OPTIMIZATION_COMPLETE] / [OPTIMIZATION_FAILED].
# This is the defense-in-depth ceiling that prevents runaway cost when the
# agent fails to self-police max_iterations from the spec.
CGF_MAX_ITERATIONS=3

# Baseline-integrity protection: SHA-256 the original (unversioned) resource
# file at start of run; re-hash before each phase signal.  Mismatch hard-fails
# the run.  Default ON (1).  Set to 0 / false to disable.
CGF_BASELINE_HASH_CHECK=1

# Signal watchdog strict mode: when the orchestrator writes a versioned
# *-v{N}.md file but does NOT emit [ITERATION_COMPLETE] in the same turn,
# warn (default, 0) or hard-fail (1).
CGF_SIGNAL_STRICT=0

# Enable iteration review & feedback
# When true: Pause after each optimization iteration for user review/feedback
# When false (default): Run all iterations autonomously
CGF_ITERATION_REVIEW=false

# Evaluation model for test scoring: sonnet (default), haiku (faster), opus (higher quality)
CGF_EVAL_MODEL=sonnet

# -----------------------------------------------------------------------------
# CGF Stage 3 — Eval Framework (Phase A)
# -----------------------------------------------------------------------------
# These vars control the EVAL_DESIGN and EXECUTION_EVAL phases that run a
# two-arm baseline-vs-candidate eval after each ITERATE round.  See
# docs/CGF-EVAL-FRAMEWORK.md for the full design.

# Model used by cgf-eval-architect to design the eval suite.
# Aliases: sonnet (default), haiku (faster), opus (best for complex specs).
CGF_DESIGN_MODEL=sonnet

# Model used by the LLM-judge grader inside EXECUTION_EVAL.  Default opus
# because judge scoring is the highest-value LLM call in the pipeline —
# weak judges produce noisy promotion decisions.  Override to sonnet/haiku
# only when you trust your rubrics enough to tolerate cheaper scoring.
CGF_JUDGE_MODEL=opus

# Hard token budget for one full eval run (per resource × per arm × all
# scenarios × trials_per_scenario).  Defaults to 1M tokens.  Used for
# observability + cost-warn; not currently a hard cutoff.
CGF_EVAL_TOKEN_BUDGET=1000000

# Promotion threshold: a candidate promotes when
#   candidate.pass_rate ≥ baseline.pass_rate + epsilon
# Default 0.0 (any strict improvement promotes).  Increase to require
# clearer wins; decrease (negative) at your own risk.
CGF_EVAL_PROMOTION_EPSILON=0.0

# Target fraction of generated scenarios that the eval-architect should
# mark held_out: true.  Held-out scenarios drive the promotion gate but
# are NEVER shown to the optimizer in feedback prompts.
CGF_EVAL_HELD_OUT_FRACTION=0.25

# Enable verbose output during optimization
CGF_VERBOSE=true

# -----------------------------------------------------------------------------
# Token Tracking & Caching
# -----------------------------------------------------------------------------

# Enable token usage tracking (for budget monitoring and cost analysis)
# Set to true to enable, false to disable (default: false for initial testing)
CGF_TOKEN_TRACKING=false

# Token budget limit (0 = unlimited, any positive number = max tokens)
# Only enforced when CGF_TOKEN_TRACKING=true
CGF_TOKEN_BUDGET=0

# Enable caching for repeated optimization runs (skip unchanged phases)
# Set to true to enable, false to disable (default: false for initial testing)
CGF_CACHE_ENABLED=false


# =============================================================================
# Feature Flags
# =============================================================================

# Enable experimental features
ENABLE_AUTO_SCALING=false
ENABLE_DISTRIBUTED_TRACING=false
ENABLE_COST_OPTIMIZATION=true

# =============================================================================
# Development Settings
# =============================================================================

# Enable debug mode (more verbose logging, slower)
DEBUG=false

# Enable hot reload for development
HOT_RELOAD=true

# Enable profiling
ENABLE_PROFILING=false

# =============================================================================
# Backup Configuration
# =============================================================================

# Backup settings
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400  # 24 hours
BACKUP_RETENTION_DAYS=7
BACKUP_STORAGE_PATH=/backups

# S3 Backup (optional)
S3_BACKUP_ENABLED=false
S3_BACKUP_BUCKET=
S3_BACKUP_PREFIX=claude-harness/

# =============================================================================
# Network Configuration
# =============================================================================

# Service Ports
MAIN_AGENT_PORT=8080
AGENT_TWO_PORT=8081
AGENT_THREE_PORT=8082
ORCHESTRATOR_PORT=8083

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=3s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=10s
