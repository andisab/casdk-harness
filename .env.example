# =============================================================================
# Claude Agent SDK Harness - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# =============================================================================
# Required Configuration
# =============================================================================

# Anthropic API Key (Required)
ANTHROPIC_API_KEY=sk-ant-your_api_key_here


# =============================================================================
# CLI Authentication (NOT MCP - used by gh and glab commands)
# =============================================================================
# These are for the GitHub CLI (gh) and GitLab CLI (glab), not MCP servers.
# Alternatively, run `gh auth login` or `glab auth login` inside the container.

# GitHub CLI: Set GITHUB_PERSONAL_ACCESS_TOKEN or run `gh auth login`
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# GitLab CLI: Set GITLAB_PERSONAL_ACCESS_TOKEN or run `glab auth login`
# GITLAB_PERSONAL_ACCESS_TOKEN=glpat-your_token_here


# =============================================================================
# MCP Server API Keys
# =============================================================================
# Copy this file to .env.mcp and fill in your values.
# This file is loaded automatically by docker-compose.yml via the env_file directive.
# Add new MCP server credentials here without modifying docker-compose.yml.

# =============================================================================
# Agent Configuration
# =============================================================================

# Claude Model Selection
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Permission Mode for Interactive Mode (see AUTONOMOUS_PERMISSION_MODE for autonomous)
# - default: Require approval for each action (safest)
# - acceptEdits: Auto-approve file edits, prompt for other actions (recommended)
# - bypassPermissions: Fully autonomous (use with caution)
CLAUDE_PERMISSION_MODE=acceptEdits

# Agent Behavior
CLAUDE_MAX_TURNS=1000
CLAUDE_SESSION_TIMEOUT=72000  # 20 hours in seconds
CLAUDE_CHECKPOINT_INTERVAL=3600  # 1 hour in seconds
CLAUDE_API_TIMEOUT=900  # 15 minutes inactivity timeout (resets on each message)
CLAUDE_AGENT_VERBOSE=true  # Show progress for subagent invocations (true/false)

# =============================================================================
# Infrastructure Configuration
# =============================================================================

# Docker BuildKit
DOCKER_BUILDKIT=1
BUILDKIT_PROGRESS=plain
COMPOSE_DOCKER_CLI_BUILD=1

# Project Configuration
COMPOSE_PROJECT_NAME=claude-harness
REGISTRY=ghcr.io/andisab/claudeagentsdk-harness
IMAGE_TAG=latest

# Environment: development | staging | production
ENVIRONMENT=development

# Platform (auto-detected for OrbStack)
# linux/amd64 | linux/arm64
PLATFORM=linux/arm64

# =============================================================================
# Resource Limits
# =============================================================================

# Main Agent Resources
AGENT_CPU_LIMIT=4
AGENT_MEMORY_LIMIT=8G
AGENT_CPU_RESERVATION=2
AGENT_MEMORY_RESERVATION=4G

# Agent Two Resources (Default: Evaluator)
AGENT_TWO_CPU_LIMIT=2
AGENT_TWO_MEMORY_LIMIT=4G

# Agent Three Resources (Default: Validator)
AGENT_THREE_CPU_LIMIT=2
AGENT_THREE_MEMORY_LIMIT=4G

# =============================================================================
# Autonomous Mode Configuration
# =============================================================================

# Delay between autonomous sessions (seconds)
# Note: Code default is 5 if not set
AUTONOMOUS_DELAY_SECONDS=3

# Maximum number of autonomous sessions before stopping
AUTONOMOUS_MAX_SESSIONS=100

# Timeout per task in seconds (default: 30 minutes)
AUTONOMOUS_TASK_TIMEOUT=1800

# Permission Mode for Autonomous Mode (separate from interactive CLAUDE_PERMISSION_MODE)
# - acceptEdits: Auto-approve file edits, prompt for other actions
# - bypassPermissions: Fully autonomous, no prompts (default for autonomous mode)
# - default: Require approval for each action
AUTONOMOUS_PERMISSION_MODE=bypassPermissions

# Bypass bash command security checks (DANGEROUS - use only for trusted workloads)
# BASH_ALLOW_ALL=false

# =============================================================================
# Monitoring & Observability
# =============================================================================

# Grafana Configuration
GRAFANA_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION
GRAFANA_PORT=3000

# Prometheus Configuration
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# Logging Configuration
# LOG_LEVEL controls verbosity of system logs (not chat output)
# - DEBUG: Everything including function calls, metrics, internal operations
# - INFO: Session events, agent actions, checkpoint saves (DEFAULT)
# - WARNING: Only warnings and errors (recommended for clean interactive chat)
# - ERROR: Only errors and critical failures
# - CRITICAL: Only catastrophic failures
#
# For interactive sessions: Use WARNING for cleaner output, or use --quiet flag
# For debugging: Use DEBUG or INFO
LOG_LEVEL=INFO

# LOG_FORMAT controls log output format
# - json: Structured JSON logs for production/parsing (recommended)
# - text: Human-readable text logs for development
LOG_FORMAT=json

# =============================================================================
# Cache Configuration (Optional)
# =============================================================================

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION

# =============================================================================
# Cloud Provider Configuration (Optional)
# =============================================================================

# AWS Bedrock (set to 1 to enable)
CLAUDE_CODE_USE_BEDROCK=0
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GCP Vertex AI (set to 1 to enable)
CLAUDE_CODE_USE_VERTEX=0
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=
GCP_REGION=us-central1

# =============================================================================
# Security Configuration
# =============================================================================

# Secret rotation interval (days)
SECRET_ROTATION_DAYS=30

# Session token settings
SESSION_SECRET=CHANGE_ME_BEFORE_PRODUCTION
SESSION_TIMEOUT=3600  # 1 hour

# Metrics endpoint authentication (optional - leave empty to disable auth)
# Format: username:password for basic auth
METRICS_AUTH_TOKEN=

# =============================================================================
# Multi-Agent Mode
# =============================================================================
# By default, only main-agent + monitoring (prometheus/grafana) start.
# Use `make dev-multi` or `make up-multi` to enable multi-agent services.
#
# Multi-agent includes:
#   - agent-two: Evaluator (read-only workspace access, default: code review)
#   - agent-three: Validator (full workspace access, default: testing)
#   - redis: Inter-agent communication (Redis Streams)
#
# To enable multi-agent mode:
#   - make dev-multi        (development with hot-reload)
#   - make up-multi         (background services)
#   - make down             (stops all services including multi-agent)
#
# Each agent loads its dedicated system prompt from src/harness/prompts/:
#   - main-agent: main-interactivedev-agent.md
#   - agent-two: agent-two.md
#   - agent-three: agent-three.md

# =============================================================================
# Plugin Configuration
# =============================================================================

# Comma-separated list of enabled plugins (leave empty for all discovered)
# Example: ENABLED_PLUGINS=context-engineering,research-team
ENABLED_PLUGINS=

# Disable plugin workarounds and rely only on SDK plugin loading
# Set to true when SDK plugin limitation is fixed
PLUGIN_USE_SDK_ONLY=false

# =============================================================================
# Feature Flags
# =============================================================================

# Enable experimental features
ENABLE_AUTO_SCALING=false
ENABLE_DISTRIBUTED_TRACING=false
ENABLE_COST_OPTIMIZATION=true

# =============================================================================
# Development Settings
# =============================================================================

# Enable debug mode (more verbose logging, slower)
DEBUG=false

# Enable hot reload for development
HOT_RELOAD=true

# Enable profiling
ENABLE_PROFILING=false

# =============================================================================
# Backup Configuration
# =============================================================================

# Backup settings
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400  # 24 hours
BACKUP_RETENTION_DAYS=7
BACKUP_STORAGE_PATH=/backups

# S3 Backup (optional)
S3_BACKUP_ENABLED=false
S3_BACKUP_BUCKET=
S3_BACKUP_PREFIX=claude-harness/

# =============================================================================
# Network Configuration
# =============================================================================

# Service Ports
MAIN_AGENT_PORT=8080
AGENT_TWO_PORT=8081
AGENT_THREE_PORT=8082
ORCHESTRATOR_PORT=8083

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=3s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=10s
