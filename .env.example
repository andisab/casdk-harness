# =============================================================================
# Claude Agent SDK Harness - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# =============================================================================
# Required Configuration
# =============================================================================

# Anthropic API Key (Required)
ANTHROPIC_API_KEY=sk-ant-your_api_key_here

# Github Personal Access Token (Optional)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# Joplin API Key (Optional)
JOPLIN_API_TOKEN=your_joplin_key_here

# =============================================================================
# Agent Configuration
# =============================================================================

# Claude Model Selection
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Permission Mode: manual | acceptEdits | acceptAll
# - manual: Require approval for each action (safest)
# - acceptEdits: Auto-approve file edits, prompt for other actions (recommended)
# - acceptAll: Fully autonomous (use with caution)
CLAUDE_PERMISSION_MODE=acceptEdits

# Agent Behavior
CLAUDE_MAX_TURNS=1000
CLAUDE_SESSION_TIMEOUT=72000  # 20 hours in seconds
CLAUDE_CHECKPOINT_INTERVAL=3600  # 1 hour in seconds

# =============================================================================
# Infrastructure Configuration
# =============================================================================

# Docker BuildKit
DOCKER_BUILDKIT=1
BUILDKIT_PROGRESS=plain
COMPOSE_DOCKER_CLI_BUILD=1

# Project Configuration
COMPOSE_PROJECT_NAME=claude-harness
REGISTRY=ghcr.io/andisab/claudeagentsdk-harness
IMAGE_TAG=latest

# Environment: development | staging | production
ENVIRONMENT=development

# Platform (auto-detected for OrbStack)
# linux/amd64 | linux/arm64
PLATFORM=linux/arm64

# =============================================================================
# Resource Limits
# =============================================================================

# Main Agent Resources
AGENT_CPU_LIMIT=4
AGENT_MEMORY_LIMIT=8G
AGENT_CPU_RESERVATION=2
AGENT_MEMORY_RESERVATION=4G

# Reviewer Agent Resources
REVIEWER_CPU_LIMIT=2
REVIEWER_MEMORY_LIMIT=4G

# Tester Agent Resources
TESTER_CPU_LIMIT=2
TESTER_MEMORY_LIMIT=4G

# =============================================================================
# Monitoring & Observability
# =============================================================================

# Grafana Configuration
GRAFANA_PASSWORD=changeme123
GRAFANA_PORT=3000

# Prometheus Configuration
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# Logging Configuration
# LOG_LEVEL controls verbosity of system logs (not chat output)
# - DEBUG: Everything including function calls, metrics, internal operations
# - INFO: Session events, agent actions, checkpoint saves (DEFAULT)
# - WARNING: Only warnings and errors (recommended for clean interactive chat)
# - ERROR: Only errors and critical failures
# - CRITICAL: Only catastrophic failures
#
# For interactive sessions: Use WARNING for cleaner output, or use --quiet flag
# For debugging: Use DEBUG or INFO
LOG_LEVEL=INFO

# LOG_FORMAT controls log output format
# - json: Structured JSON logs for production/parsing (recommended)
# - text: Human-readable text logs for development
LOG_FORMAT=json

# =============================================================================
# Database Configuration (Optional)
# =============================================================================

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=claude_harness
POSTGRES_USER=claude
POSTGRES_PASSWORD=changeme_postgres_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# =============================================================================
# Cloud Provider Configuration (Optional)
# =============================================================================

# AWS Bedrock (set to 1 to enable)
CLAUDE_CODE_USE_BEDROCK=0
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GCP Vertex AI (set to 1 to enable)
CLAUDE_CODE_USE_VERTEX=0
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=
GCP_REGION=us-central1

# =============================================================================
# Security Configuration
# =============================================================================

# Secret rotation interval (days)
SECRET_ROTATION_DAYS=30

# Session token settings
SESSION_SECRET=changeme_session_secret
SESSION_TIMEOUT=3600  # 1 hour

# =============================================================================
# Feature Flags
# =============================================================================

# Enable experimental features
ENABLE_AUTO_SCALING=false
ENABLE_DISTRIBUTED_TRACING=false
ENABLE_COST_OPTIMIZATION=true

# =============================================================================
# Development Settings
# =============================================================================

# Enable debug mode (more verbose logging, slower)
DEBUG=false

# Enable hot reload for development
HOT_RELOAD=true

# Enable profiling
ENABLE_PROFILING=false

# =============================================================================
# Backup Configuration
# =============================================================================

# Backup settings
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400  # 24 hours
BACKUP_RETENTION_DAYS=7
BACKUP_STORAGE_PATH=/backups

# S3 Backup (optional)
S3_BACKUP_ENABLED=false
S3_BACKUP_BUCKET=
S3_BACKUP_PREFIX=claude-harness/

# =============================================================================
# Network Configuration
# =============================================================================

# Service Ports
MAIN_AGENT_PORT=8080
REVIEWER_AGENT_PORT=8081
TESTER_AGENT_PORT=8082
ORCHESTRATOR_PORT=8083

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=3s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=10s
