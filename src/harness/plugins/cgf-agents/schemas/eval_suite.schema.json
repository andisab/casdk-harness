{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CGF Evaluation Suite",
  "description": "Schema for eval suites generated by cgf-eval-architect (CGF Stage 3 Phase A). Defines scenarios, graders, and run configuration for two-arm baseline-vs-candidate evaluation.",
  "type": "object",
  "required": ["version", "target_resource", "scenarios", "config"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Suite schema version (semver). Currently '1.0'.",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "target_resource": {
      "type": "string",
      "description": "Path to the resource being evaluated (e.g., 'agents/iac-analyzer.md'). Per-scenario overrides are supported."
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of what this eval suite measures."
    },
    "scenarios": {
      "type": "array",
      "description": "List of evaluation scenarios. Held-out scenarios (held_out: true) are excluded from optimizer feedback.",
      "minItems": 1,
      "items": { "$ref": "#/definitions/scenario" }
    },
    "config": { "$ref": "#/definitions/config" },
    "metadata": {
      "type": "object",
      "description": "Free-form metadata (generator, timestamp, source resource-plan, etc.)",
      "additionalProperties": true
    }
  },
  "definitions": {
    "config": {
      "type": "object",
      "description": "Suite-level run configuration",
      "additionalProperties": false,
      "properties": {
        "trials_per_scenario": {
          "type": "integer",
          "description": "Number of independent trials per scenario per arm (used for pass@k computation)",
          "minimum": 1,
          "maximum": 100,
          "default": 3
        },
        "timeout_seconds": {
          "type": "integer",
          "description": "Per-trial timeout in seconds",
          "minimum": 1,
          "maximum": 3600,
          "default": 300
        },
        "eval_model": {
          "type": "string",
          "description": "Default LLM-judge model identifier (e.g., 'claude-opus-4-5-20250929'). Overridable per llm_judge grader.",
          "default": "claude-opus-4-5-20250929"
        },
        "token_budget": {
          "type": "integer",
          "description": "Hard token budget for the entire run. Hits CGF_EVAL_TOKEN_BUDGET if not specified.",
          "minimum": 1000
        },
        "held_out_fraction": {
          "type": "number",
          "description": "Target fraction of scenarios to mark held_out: true (informational; held_out is set per-scenario).",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.25
        }
      }
    },
    "scenario": {
      "type": "object",
      "required": ["id", "level", "prompt", "graders"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique scenario identifier (kebab-case)",
          "pattern": "^[a-z0-9][a-z0-9_-]*$",
          "minLength": 1,
          "maxLength": 80
        },
        "level": {
          "type": "string",
          "description": "Eval granularity",
          "enum": ["unit", "trajectory", "e2e"]
        },
        "target_resource": {
          "type": "string",
          "description": "Resource override for this scenario (defaults to suite-level target_resource)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what this scenario tests"
        },
        "prompt": {
          "type": "string",
          "description": "User prompt sent to the agent under test",
          "minLength": 1
        },
        "setup": {
          "type": "object",
          "description": "Workspace setup for this scenario",
          "additionalProperties": false,
          "properties": {
            "files": {
              "type": "array",
              "description": "Files to create in the scenario workspace before the prompt is run",
              "items": {
                "type": "object",
                "required": ["path", "content"],
                "additionalProperties": false,
                "properties": {
                  "path": {
                    "type": "string",
                    "description": "Relative path within scenario workspace (no '..' allowed)",
                    "pattern": "^(?!.*\\.\\.)([^/].*)?$"
                  },
                  "content": {
                    "type": "string",
                    "description": "File contents (UTF-8 text)"
                  }
                }
              },
              "default": []
            },
            "env": {
              "type": "object",
              "description": "Additional environment variables for this scenario",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "graders": {
          "type": "array",
          "description": "Graders applied to this scenario's transcript. All must pass for scenario to pass (unless wrapped in composite OR).",
          "minItems": 1,
          "items": { "$ref": "#/definitions/grader" }
        },
        "tags": {
          "type": "array",
          "description": "Free-form tags for filtering and rollups (e.g., 'easy', 'security', 'happy-path')",
          "items": { "type": "string" },
          "default": []
        },
        "held_out": {
          "type": "boolean",
          "description": "If true, this scenario is excluded from optimizer feedback (used only for promotion gating in EXECUTION_EVAL).",
          "default": false
        },
        "difficulty": {
          "type": "string",
          "description": "Eval-architect's difficulty estimate (40/40/20 split target)",
          "enum": ["easy", "medium", "hard"]
        },
        "cost_gate_exempt": {
          "type": "boolean",
          "description": "Phase A refinement 4.3: opt this scenario out of the per-arm cost-per-success gate. Quality gate still counts the scenario; only the cost aggregate excludes it. Use for scenarios where verbose chain-of-thought / tool-trace logging is intentional. Per-scenario opt-in only; no resource-type-level fallback.",
          "default": false
        }
      }
    },
    "grader": {
      "description": "Polymorphic grader. Discriminator: 'type'. Subtype-specific fields validated by oneOf below.",
      "type": "object",
      "required": ["type"],
      "oneOf": [
        { "$ref": "#/definitions/grader_exact" },
        { "$ref": "#/definitions/grader_contains" },
        { "$ref": "#/definitions/grader_regex" },
        { "$ref": "#/definitions/grader_code" },
        { "$ref": "#/definitions/grader_trajectory" },
        { "$ref": "#/definitions/grader_llm_judge" },
        { "$ref": "#/definitions/grader_composite" }
      ]
    },
    "grader_exact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "expected"],
      "properties": {
        "type": { "const": "exact" },
        "expected": {
          "type": "string",
          "description": "Exact expected final-output string"
        },
        "field": {
          "type": "string",
          "description": "Which transcript field to compare against",
          "enum": ["final_output", "last_message"],
          "default": "final_output"
        }
      }
    },
    "grader_contains": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "needle"],
      "properties": {
        "type": { "const": "contains" },
        "needle": {
          "type": "string",
          "description": "Substring that must appear in target field"
        },
        "case_insensitive": {
          "type": "boolean",
          "default": false
        },
        "field": {
          "type": "string",
          "enum": ["final_output", "last_message", "any_message"],
          "default": "final_output"
        }
      }
    },
    "grader_regex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "pattern"],
      "properties": {
        "type": { "const": "regex" },
        "pattern": {
          "type": "string",
          "description": "Python re pattern (anchored implicitly per re.search semantics)"
        },
        "flags": {
          "type": "array",
          "description": "Python re flags by name",
          "items": {
            "type": "string",
            "enum": ["IGNORECASE", "MULTILINE", "DOTALL", "VERBOSE"]
          },
          "default": []
        },
        "field": {
          "type": "string",
          "enum": ["final_output", "last_message", "any_message"],
          "default": "final_output"
        }
      }
    },
    "grader_code": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "code"],
      "properties": {
        "type": { "const": "code" },
        "code": {
          "type": "string",
          "description": "Python snippet executed in a sandbox. Has access to `transcript` (AgentTranscript) and `scenario`. Must call `assert` to fail; returning normally passes.",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "enum": ["python"],
          "default": "python",
          "description": "Currently only python is supported"
        }
      }
    },
    "grader_trajectory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "assertions"],
      "properties": {
        "type": { "const": "trajectory" },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/trajectory_assertion" }
        }
      }
    },
    "trajectory_assertion": {
      "description": "Polymorphic trajectory assertion. Discriminator: 'kind'.",
      "type": "object",
      "required": ["kind"],
      "oneOf": [
        { "$ref": "#/definitions/trajectory_tool_called" },
        { "$ref": "#/definitions/trajectory_no_tool" },
        { "$ref": "#/definitions/trajectory_ordering" },
        { "$ref": "#/definitions/trajectory_constraint" }
      ]
    },
    "trajectory_tool_called": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "tool"],
      "properties": {
        "kind": { "const": "tool_called" },
        "tool": {
          "type": "string",
          "description": "Tool name (matches ToolCall.tool_name)"
        },
        "min_count": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "with_arg": {
          "type": "object",
          "description": "Optional argument-value pairs that must match this call",
          "additionalProperties": true
        }
      }
    },
    "trajectory_no_tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "tool"],
      "properties": {
        "kind": { "const": "no_tool" },
        "tool": {
          "type": "string",
          "description": "Tool name that must NOT be called"
        }
      }
    },
    "trajectory_ordering": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "before", "after"],
      "properties": {
        "kind": { "const": "ordering" },
        "before": {
          "type": "string",
          "description": "Tool that must be called first"
        },
        "after": {
          "type": "string",
          "description": "Tool that must be called after `before`"
        }
      }
    },
    "trajectory_constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "text"],
      "properties": {
        "kind": { "const": "constraint" },
        "text": {
          "type": "string",
          "description": "Natural-language constraint to verify against the transcript via LLM-judge"
        }
      }
    },
    "grader_llm_judge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "rubric"],
      "properties": {
        "type": { "const": "llm_judge" },
        "rubric": {
          "type": "string",
          "description": "Rubric prompt for the judge model. Should describe scoring on a 1-5 scale.",
          "minLength": 10
        },
        "pass_threshold": {
          "type": "number",
          "description": "Minimum normalized score (0.0-1.0) to count as pass. Score 1-5 is normalized to (score-1)/4.",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.7
        },
        "eval_model": {
          "type": "string",
          "description": "Override suite-level eval_model for this grader"
        },
        "pairwise": {
          "type": "boolean",
          "description": "Phase B: enable pairwise A-B + B-A position-balanced comparison instead of solo scoring",
          "default": false
        }
      }
    },
    "grader_composite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "operator", "graders"],
      "properties": {
        "type": { "const": "composite" },
        "operator": {
          "type": "string",
          "enum": ["and", "or"]
        },
        "graders": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/grader" }
        }
      }
    }
  }
}
