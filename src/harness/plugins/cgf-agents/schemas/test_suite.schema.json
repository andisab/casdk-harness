{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CGF Test Suite",
  "description": "Schema for test suites generated by cgf-test-architect for agent optimization",
  "type": "object",
  "required": ["name", "agent_name", "test_cases"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Suite name/identifier"
    },
    "agent_name": {
      "type": "string",
      "description": "Target agent for these tests"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the test suite",
      "default": ""
    },
    "version": {
      "type": "string",
      "description": "Suite version for tracking changes",
      "default": "1.0"
    },
    "test_cases": {
      "type": "array",
      "description": "List of test cases in this suite",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "prompt", "expected_behavior", "validation"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for this test case",
            "pattern": "^[a-z0-9-_]+$"
          },
          "prompt": {
            "type": "string",
            "description": "Task prompt to send to the agent",
            "minLength": 10
          },
          "expected_behavior": {
            "type": "string",
            "description": "Human-readable description of expected behavior"
          },
          "validation": {
            "type": "object",
            "description": "Configuration for validating agent output",
            "required": ["type", "criteria"],
            "properties": {
              "type": {
                "type": "string",
                "description": "Validation method",
                "enum": ["exact", "contains", "regex", "llm_judge", "code", "code_syntax", "code_llm"]
              },
              "criteria": {
                "type": "string",
                "description": "Match criteria - exact string, substring, regex pattern, or LLM judge prompt"
              },
              "partial_credit": {
                "type": "boolean",
                "description": "If true, allows partial scores (0.0-1.0). If false, only 0.0 or 1.0.",
                "default": false
              },
              "language": {
                "type": "string",
                "description": "Programming language for code validation",
                "default": "python"
              },
              "require_syntax_valid": {
                "type": "boolean",
                "description": "If true, code must be syntactically valid to pass",
                "default": true
              },
              "min_code_lines": {
                "type": "integer",
                "description": "Minimum lines of code required (0 = no minimum)",
                "minimum": 0,
                "default": 0
              }
            }
          },
          "timeout_seconds": {
            "type": "integer",
            "description": "Maximum time allowed for agent execution",
            "minimum": 1,
            "maximum": 3600,
            "default": 300
          },
          "tags": {
            "type": "array",
            "description": "Optional tags for filtering test cases",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "metadata": {
            "type": "object",
            "description": "Additional context or configuration",
            "default": {}
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional suite-level configuration",
      "properties": {
        "generator": {
          "type": "string",
          "description": "Agent/tool that generated this suite"
        },
        "generated_from": {
          "type": "string",
          "description": "Path to eval_criteria.yaml used as source"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the suite was generated"
        },
        "coverage": {
          "type": "object",
          "description": "Coverage statistics",
          "properties": {
            "competencies": {
              "type": "integer",
              "description": "Number of competencies covered"
            },
            "edge_cases": {
              "type": "integer",
              "description": "Number of edge cases covered"
            },
            "common_mistakes": {
              "type": "integer",
              "description": "Number of common mistakes tested"
            }
          }
        }
      }
    }
  }
}
