# SSH Configuration for Claude Agent SDK Harness
# This file configures SSH access to GitHub and GitLab

# GitHub
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_github
    IdentitiesOnly yes
    UpdateHostKeys no

# GitLab (Provectus)
Host gitlab.provectus.com
    HostName gitlab.provectus.com
    User git
    IdentityFile ~/.ssh/id_ed25519_gitlab
    IdentitiesOnly yes
    UpdateHostKeys no
