# Git HTTPS credentials for private Git servers
# Copy this file to .netrc and fill in your credentials
# IMPORTANT: Keep .netrc secure (chmod 600 .netrc)

# GitLab Provectus
machine gitlab.provectus.com
login your_username
password your_personal_access_token

# GitHub (if needed)
# machine github.com
# login your_username  
# password your_personal_access_token
