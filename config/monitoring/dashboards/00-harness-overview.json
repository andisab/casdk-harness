{
  "title": "Claude Agent Harness \u2014 Overview",
  "uid": "casdk-overview",
  "tags": [
    "claude",
    "harness",
    "overview"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "1h"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "mode",
        "label": "Mode",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(harness_run_config_info, mode)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(harness_run_config_info, mode)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "hide": 0,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      },
      {
        "name": "resource",
        "label": "Resource",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(harness_run_phase_info{resource!~\"test_.*\"}, resource)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(harness_run_phase_info{resource!~\"test_.*\"}, resource)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "hide": 0,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      },
      {
        "name": "path",
        "label": "Path",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(harness_run_path_info == 1, path)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(harness_run_path_info == 1, path)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "hide": 0,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(claude_code_cost_usage_USD_total, model)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(claude_code_cost_usage_USD_total, model)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "hide": 0,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      }
    ]
  },
  "links": [
    {
      "title": "All Harness Dashboards",
      "type": "dashboards",
      "tags": ["claude", "harness"],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "icon": "external link"
    },
    {
      "title": "10 — SDK: Cost & Spend",
      "type": "link",
      "url": "/d/casdk-sdk-cost",
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    },
    {
      "title": "20 — SDK: Productivity",
      "type": "link",
      "url": "/d/casdk-sdk-productivity",
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    },
    {
      "title": "30 — SDK: Cache",
      "type": "link",
      "url": "/d/casdk-sdk-cache",
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    },
    {
      "title": "40 — SDK: Tools",
      "type": "link",
      "url": "/d/casdk-sdk-tools",
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    },
    {
      "title": "50 — SDK: Reliability",
      "type": "link",
      "url": "/d/casdk-sdk-reliability",
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    },
    {
      "title": "60 — Mode: Interactive",
      "type": "link",
      "url": "/d/casdk-mode-interactive",
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    },
    {
      "title": "65 — Mode: Autonomous",
      "type": "link",
      "url": "/d/casdk-mode-autonomous",
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    },
    {
      "title": "70 — Mode: CGF Optimization",
      "type": "link",
      "url": "/d/casdk-cgf",
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    },
    {
      "title": "99 — Raw Events",
      "type": "link",
      "url": "/d/casdk-raw-events",
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Session Health",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(harness_agent_active_sessions)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Sessions Started (last 1h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_session_count_total[1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 3,
      "title": "User Prompts (last 1h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(increase(harness_session_prompts_total[1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 4,
      "title": "Tokens (last 1h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total[1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 5,
      "title": "Cost (last 1h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4
        }
      }
    },
    {
      "id": 6,
      "title": "Cache Hit Ratio (last 5m)",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m])) / clamp_min(sum(rate(claude_code_token_usage_tokens_total{type=~\"cacheRead|input\"}[5m])), 1)",
          "refId": "A"
        }
      ],
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.3,
                "color": "orange"
              },
              {
                "value": 0.6,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Tokens & Cost",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Tokens/min by Model + Query Source",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "sum by (model, query_source) (rate(claude_code_token_usage_tokens_total[5m])) * 60",
          "legendFormat": "{{model}} / {{query_source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 11,
      "title": "Cost ($/hour) by Model",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(claude_code_cost_usage_USD_total[5m])) * 3600",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 12,
      "title": "Token Type Mix (input / output / cacheRead / cacheCreation)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total[5m])) * 60",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 13,
      "title": "Cumulative Cost (selected range)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 14
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4
        }
      }
    },
    {
      "id": 14,
      "title": "Cost per Session (mean, range)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 14
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range])) / clamp_min(sum(increase(claude_code_session_count_total[$__range])), 1)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4
        }
      }
    },
    {
      "id": 15,
      "title": "Top Models by Cost (selected range)",
      "type": "bargauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 18
      },
      "targets": [
        {
          "expr": "topk(5, sum by (model) (increase(claude_code_cost_usage_USD_total[$__range])))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4
        }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Tools & Messages",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "collapsed": false
    },
    {
      "id": 20,
      "title": "Tool Calls by Name (selected range)",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 23
      },
      "targets": [
        {
          "expr": "topk(15, sum by (tool_name) (increase(harness_tool_calls_total[$__range])))",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 21,
      "title": "Tool Error Rate (last 5m)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 23
      },
      "targets": [
        {
          "expr": "sum by (tool_name) (rate(harness_tool_calls_total{status=\"error\"}[5m]))",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 22,
      "title": "Message Type Distribution",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 31
      },
      "targets": [
        {
          "expr": "sum by (message_type) (increase(harness_message_types_total[$__range]))",
          "legendFormat": "{{message_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 23,
      "title": "Agent Request Rate by Status",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 31
      },
      "targets": [
        {
          "expr": "sum by (agent, status) (rate(harness_agent_requests_total[5m]))",
          "legendFormat": "{{agent}} \u2014 {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 400,
      "type": "row",
      "title": "Latency",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 39
      },
      "collapsed": false
    },
    {
      "id": 30,
      "title": "Agent Request Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, agent) (rate(harness_agent_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 \u2014 {{agent}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, agent) (rate(harness_agent_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 \u2014 {{agent}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, agent) (rate(harness_agent_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 \u2014 {{agent}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 31,
      "title": "Session Duration Heatmap",
      "type": "heatmap",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(harness_session_duration_seconds_bucket[5m]))",
          "legendFormat": "{{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ],
      "options": {
        "yAxis": {
          "unit": "s"
        },
        "calculate": false
      }
    },
    {
      "id": 500,
      "type": "row",
      "title": "System",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 48
      },
      "collapsed": true,
      "panels": [
        {
          "id": 40,
          "title": "Checkpoint Size",
          "type": "stat",
          "gridPos": {
            "h": 4,
            "w": 6,
            "x": 0,
            "y": 49
          },
          "targets": [
            {
              "expr": "harness_checkpoint_size_bytes",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "bytes"
            }
          }
        },
        {
          "id": 41,
          "title": "Workspace Files",
          "type": "stat",
          "gridPos": {
            "h": 4,
            "w": 6,
            "x": 6,
            "y": 49
          },
          "targets": [
            {
              "expr": "harness_workspace_files_total",
              "refId": "A"
            }
          ]
        },
        {
          "id": 42,
          "title": "Memory Usage by Component",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 49
          },
          "targets": [
            {
              "expr": "sum by (component) (harness_memory_usage_bytes)",
              "legendFormat": "{{component}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "bytes"
            }
          }
        }
      ]
    }
  ]
}
