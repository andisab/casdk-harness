  "panels": [
    {
      "id": 301,
      "type": "row",
      "title": "Active Run Status",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 303,
      "title": "Active Resource",
      "type": "stat",
      "description": "Workspace name of the resource currently being optimized. Source: harness_run_phase_info{resource}.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "expr": "topk(1, max by (resource) (last_over_time(harness_run_phase_info{resource!~\"test_.*\"}[2h]) > 0))",
          "refId": "A",
          "instant": true,
          "legendFormat": "{{resource}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "name",
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 304,
      "title": "Iteration",
      "type": "stat",
      "description": "Current optimization iteration (single-resource path).",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "max(last_over_time(harness_run_iteration{resource!~\"test_.*\"}[2h]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 8
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 305,
      "title": "Cost (selected range)",
      "type": "stat",
      "description": "Total Claude API cost across all models in the selected time range. Source: claude_code_cost_usage_USD_total (SDK-native).",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 9
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "currencyUSD",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 306,
      "title": "Tokens (selected range)",
      "type": "stat",
      "description": "Total tokens consumed across all models / query sources in the selected time range. Source: claude_code_token_usage_tokens_total.",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 18,
        "y": 9
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total[$__range]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500000
              },
              {
                "color": "red",
                "value": 5000000
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "Tracer Activity",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Spans Collected (selected range)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 15
      },
      "targets": [
        {
          "expr": "sum(increase(cgf_spans_collected_total[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "Spans Exported (selected range)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 15
      },
      "targets": [
        {
          "expr": "sum(increase(cgf_spans_exported_total[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Adapter Transform Success Rate",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 15
      },
      "targets": [
        {
          "expr": "sum(increase(cgf_adapter_transforms_total{status=\"success\"}[$__range])) / clamp_min(sum(increase(cgf_adapter_transforms_total[$__range])), 1)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.8,
                "color": "orange"
              },
              {
                "value": 0.95,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Mean Composite Reward (selected range)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 15
      },
      "targets": [
        {
          "expr": "sum(rate(cgf_reward_composite_sum[$__range])) / clamp_min(sum(rate(cgf_reward_composite_count[$__range])), 1)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.5,
                "color": "orange"
              },
              {
                "value": 0.75,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Spans Collected/min by Kind",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "targets": [
        {
          "expr": "sum by (span_kind) (rate(cgf_spans_collected_total[5m])) * 60",
          "legendFormat": "{{span_kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 11,
      "title": "Spans Exported/min by Exporter",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "targets": [
        {
          "expr": "sum by (exporter) (rate(cgf_spans_exported_total[5m])) * 60",
          "legendFormat": "{{exporter}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Optimization Quality",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "collapsed": false
    },
    {
      "id": 20,
      "title": "Composite Reward Distribution by Resource Type",
      "type": "heatmap",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(cgf_reward_composite_bucket[5m]))",
          "legendFormat": "{{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ],
      "options": {
        "yAxis": {
          "unit": "short"
        },
        "calculate": false
      }
    },
    {
      "id": 21,
      "title": "Feedback Dimensions (current)",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "targets": [
        {
          "expr": "avg by (resource_type, dimension) (cgf_feedback_dimensions)",
          "legendFormat": "{{resource_type}} / {{dimension}}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "decimals": 3
        }
      }
    },
    {
      "id": 22,
      "title": "Adapter Transforms by Resource Type & Status",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "expr": "sum by (resource_type, status) (rate(cgf_adapter_transforms_total[5m])) * 60",
          "legendFormat": "{{resource_type}} \u2014 {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Eval Framework (Stage 3 Phase A)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 44
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 30,
      "title": "Eval Phase Duration (p50, p95)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 45
      },
      "description": "Wall-clock duration of EVAL_DESIGN and EXECUTION_EVAL phases.  EVAL_DESIGN should usually complete within minutes; EXECUTION_EVAL scales with scenario count \u00d7 trials \u00d7 arms.",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(harness_eval_phase_duration_seconds_bucket[5m])) by (phase, le))",
          "legendFormat": "p50 {{phase}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(harness_eval_phase_duration_seconds_bucket[5m])) by (phase, le))",
          "legendFormat": "p95 {{phase}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 31,
      "title": "Tokens to Goal (per resource type)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 45
      },
      "description": "Distribution of tokens spent until a candidate promotes, observed at promotion time.  Phase A approximation: per-run total only; Phase B will include cumulative tokens across feedback iterations.",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(harness_eval_tokens_to_goal_bucket[15m])) by (resource_type, le))",
          "legendFormat": "p50 {{resource_type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(harness_eval_tokens_to_goal_bucket[15m])) by (resource_type, le))",
          "legendFormat": "p95 {{resource_type}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 32,
      "title": "Scenarios by Outcome (rate)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 53
      },
      "description": "Per-scenario outcomes by arm.  The candidate ``pass`` rate climbing while ``fail`` and ``no_decision`` shrink is the visual signature of a healthy optimizer loop.",
      "targets": [
        {
          "expr": "sum(rate(harness_eval_scenarios_total[5m])) by (status, arm)",
          "legendFormat": "{{arm}} \u2014 {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 33,
      "title": "Per-Arm Pass Rate Distribution (last 1h)",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 53
      },
      "description": "Histogram-quantile view of per-scenario arm pass-rates.  Compare candidate p50 vs baseline p50 to read promotion strength at a glance.",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(harness_eval_arm_score_bucket[1h])) by (arm, level, le))",
          "legendFormat": "p50 {{arm}} ({{level}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        }
      }
    },
    {
      "id": 34,
      "title": "LLM-Judge No-Decision Events",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 61
      },
      "description": "How often the LLM-judge grader hits the retry-once-then-mark-no-decision escape hatch.  A non-trivial rate here means the judge model is unstable for the current rubrics \u2014 either tighten rubrics, switch to a stronger judge model, or (Phase B) enable the judge-ensemble fallback.",
      "targets": [
        {
          "expr": "sum(rate(harness_eval_judge_no_decision_total[15m])) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 307,
      "title": "Phase Progression",
