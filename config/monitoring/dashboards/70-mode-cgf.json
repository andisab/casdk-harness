{
  "title": "Claude Agent Harness \u2014 CGF Optimization",
  "uid": "casdk-cgf",
  "tags": [
    "claude",
    "harness",
    "cgf",
    "optimization"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 14,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "1h"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "mode",
        "label": "Mode",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(harness_run_config_info, mode)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(harness_run_config_info, mode)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "hide": 0,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      },
      {
        "name": "resource",
        "label": "Resource",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(harness_run_phase_info{resource!~\"test_.*\"}, resource)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(harness_run_phase_info{resource!~\"test_.*\"}, resource)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "hide": 0,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      },
      {
        "name": "path",
        "label": "Path",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(harness_run_path_info == 1, path)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(harness_run_path_info == 1, path)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "hide": 0,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(claude_code_cost_usage_USD_total, model)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(claude_code_cost_usage_USD_total, model)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "hide": 0,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      }
    ]
  },
  "links": [
    {
      "title": "00 — Overview",
      "type": "dashboards",
      "tags": ["claude", "harness"],
      "asDropdown": true,
