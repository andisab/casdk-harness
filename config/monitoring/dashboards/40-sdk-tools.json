    {
      "id": 40200,
      "type": "timeseries",
      "title": "Acceptance Rate by tool_name",
      "description": "Edit / Write / NotebookEdit broken out.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (tool_name) (rate(claude_code_code_edit_tool_decision_total{decision=\"accept\"}[5m])) / sum by (tool_name) (rate(claude_code_code_edit_tool_decision_total[5m]))",
