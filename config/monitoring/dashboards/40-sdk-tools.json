  "panels": [
    {
      "id": 40100,
      "type": "stat",
      "title": "Edit Acceptance Rate (Overall)",
      "description": "accept / (accept + reject) across all code-edit tools. NOTE: SDK metric name is claude_code_code_edit_tool_decision_total (NOT _count_total as upstream spec lists). See METRICS-INVENTORY \u00a7 6.1.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_code_edit_tool_decision_total{decision=\"accept\"}[$__range])) / sum(rate(claude_code_code_edit_tool_decision_total[$__range]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "green",
                "value": 0.9
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 40110,
      "type": "stat",
      "title": "Accepted Edits (selected range)",
      "description": "",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
