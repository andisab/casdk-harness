  "panels": [
    {
      "id": 60100,
      "type": "stat",
      "title": "Active Sessions",
      "description": "Active interactive sessions (harness_agent_active_sessions).",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(harness_agent_active_sessions)",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text-primary"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
