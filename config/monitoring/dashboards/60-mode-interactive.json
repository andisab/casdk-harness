    {
      "id": 60200,
      "type": "timeseries",
      "title": "Conversation Flow",
      "description": "Rate of user prompts and agent responses, overlaid. Visualizes the rhythm of human-AI interaction over the session. A responsive session shows close-coupled rates; long stretches of prompt-only suggest the agent is mid-thinking or mid-tool-call.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(harness_session_prompts_total[1m])) * 60",
          "legendFormat": "prompts/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(harness_session_responses_total[1m])) * 60",
          "legendFormat": "responses/min",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      }
    },
    {
      "id": 60300,
      "type": "timeseries",
      "title": "Tool Calls (rate by tool_name, status)",
      "description": "Tool invocation rate broken out by tool_name and status. Errors and successes stack visually.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (tool_name, status) (rate(harness_tool_calls_total[5m])) * 60",
          "legendFormat": "{{tool_name}} / {{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
