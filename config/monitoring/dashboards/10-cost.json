    {
      "id": 10120,
      "type": "stat",
      "title": "Cost / Accepted Edit",
      "description": "Average cost per accepted code edit, computed as total spend ÷ total accepted edits across the dashboard range. A defensible efficiency KPI; rising values point to too much Opus where Sonnet would suffice, or over-high `effort` settings.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range])) / sum(increase(claude_code_code_edit_tool_decision_total{decision=\"accept\"}[$__range]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
