      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{model=~\"$model\",type=~\"input|cacheRead|cacheCreation\"}[24h]))",
          "refId": "A",
          "instant": false
        }
      ]
    },
