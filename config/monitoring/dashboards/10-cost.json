                }
              }
            }
          ],
          "unit": "currencyUSD",
          "decimals": 3
        },
        "overrides": []
      }
    },
    {
      "id": 10130,
      "type": "stat",
      "title": "Projected Monthly Spend",
      "description": "Average daily spend over the last 7 days × 30. Directional, not a forecast — Anthropic has re-priced Opus downward 3× within a year. Empty if Prometheus has < 7d of retained samples.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[7d])) / 7 * 30",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
