            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 30410,
      "type": "timeseries",
      "title": "Cache Hit Rate by query_source",
      "description": "Per-query_source cache hit rate. main / subagent / auxiliary. Subagents (Task tool) tend to have lower hit rates because each Task invocation pays cacheCreation for its own context \u2014 this panel surfaces the cost differential.",
      "gridPos": {
