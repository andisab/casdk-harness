  "panels": [
    {
      "id": 30100,
      "type": "stat",
      "title": "Cache Hit Rate (Overall)",
      "description": "cacheRead / (cacheRead + cacheCreation + input) over the rate interval. Healthy Claude Code sessions sit at \u226590%; <60% means cache is busted each turn (timestamps in CLAUDE.md, mid-session model switches, MCP additions, capitalization drift in stable prefixes).",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[$__rate_interval])) / sum(rate(claude_code_token_usage_tokens_total{type=~\"cacheRead|cacheCreation|input\"}[$__rate_interval]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.6
              },
              {
                "color": "green",
                "value": 0.9
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 30110,
      "type": "stat",
      "title": "Effective $/Mtok (any type)",
      "description": "Average cost per million tokens across all types. Cache reads (0.1\u00d7 input price) and cache writes (1.25\u20132\u00d7 input price) make this much lower than the model's base input price when caching is healthy. Spec \u00a7 1.4 derives a per-type formula; this is the aggregate version that doesn't require per-model base-price lookup.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_cost_usage_USD_total[5m])) * 1e6 / sum(rate(claude_code_token_usage_tokens_total[5m]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text-primary"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 30120,
      "type": "stat",
      "title": "Cache Read : Creation Ratio",
      "description": "cacheRead / cacheCreation over 5m. High = lots of reuse from cached prefixes (healthy). Low = cache is being written but evicted before reuse \u2014 TTL too short for your workflow, or system prompts are unstable across turns. Above ~10:1 is typical for a long well-cached session.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m])) / sum(rate(claude_code_token_usage_tokens_total{type=\"cacheCreation\"}[5m]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text-primary"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "id": 30200,
      "type": "timeseries",
      "title": "Cache Hit Rate \u2014 Over Time",
      "description": "Cache hit rate over time. Threshold band: \u226590% green, 60\u201380% amber, <60% red. Mid-session model switches will visibly destroy this \u2014 cache is per-model with no cross-model reuse.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[$__rate_interval])) / sum(rate(claude_code_token_usage_tokens_total{type=~\"cacheRead|cacheCreation|input\"}[$__rate_interval]))",
          "legendFormat": "cache hit rate",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "percentunit",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 30300,
      "type": "timeseries",
      "title": "Cache Hit Rate by Model",
      "description": "Per-model cache hit rate. Switching models mid-session destroys the cache for the new model until it builds up \u2014 visible here as one line dropping to 0 while the previous model's line goes flat.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[$__rate_interval])) / sum by (model) (rate(claude_code_token_usage_tokens_total{type=~\"cacheRead|cacheCreation|input\",model=~\"$model\"}[$__rate_interval]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "percentunit",
          "custom": {
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 30310,
      "type": "timeseries",
      "title": "Token Mix (stacked area)",
      "description": "Rate of each token type. A long, cache-healthy session is dominated by cacheRead (cheap). cacheCreation spikes at the start of each new prompt prefix. input/output are the residual.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "short",
          "custom": {
            "fillOpacity": 60,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 30400,
      "type": "timeseries",
      "title": "Output : Input Ratio by Model",
      "description": "output / input token rate by model. Opus 4.7's new tokenizer emits up to 35% more output tokens for the same prose; session-to-session delta surfaces the impact. The harness doesn't separate extended-thinking tokens \u2014 they fold into output.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(claude_code_token_usage_tokens_total{type=\"output\",model=~\"$model\"}[5m])) / sum by (model) (rate(claude_code_token_usage_tokens_total{type=\"input\",model=~\"$model\"}[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "custom": {
