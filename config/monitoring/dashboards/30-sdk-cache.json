          "expr": "sum by (query_source) (rate(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[$__rate_interval])) / sum by (query_source) (rate(claude_code_token_usage_tokens_total{type=~\"cacheRead|cacheCreation|input\"}[$__rate_interval]))",
          "legendFormat": "{{query_source}}",
          "refId": "A"
        }
      ],
      "options": {
