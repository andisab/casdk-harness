    {
      "id": 50200,
      "type": "timeseries",
      "title": "Error Rate by Agent",
      "description": "Per-agent error rate from harness_agent_requests_total.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (agent) (rate(harness_agent_requests_total{status=\"error\"}[5m])) / sum by (agent) (rate(harness_agent_requests_total[5m]))",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
