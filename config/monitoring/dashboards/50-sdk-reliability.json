  "panels": [
    {
      "id": 50100,
      "type": "stat",
      "title": "Harness Error Rate",
      "description": "Fraction of harness agent requests that errored. Prometheus-only proxy for SDK-side API reliability \u2014 actual `api_error` event data needs Loki (Stage 3). See METRICS-INVENTORY \u00a7 6 + GRAFANA-REFACTOR \u00a7 7.4 D50.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(harness_agent_requests_total{status=\"error\"}[5m])) / sum(rate(harness_agent_requests_total[5m]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 50110,
      "type": "stat",
      "title": "Errors (selected range)",
      "description": "Total harness-agent error count across the window.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(harness_agent_requests_total{status=\"error\"}[$__range]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
