{
  "title": "Claude Agent Harness \u2014 CGF Optimization",
  "uid": "casdk-cgf",
  "tags": [
    "claude",
    "harness",
    "cgf",
    "optimization"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "1h"
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Tracer Activity",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Spans Collected (selected range)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(increase(cgf_spans_collected_total[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "Spans Exported (selected range)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(increase(cgf_spans_exported_total[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Adapter Transform Success Rate",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(increase(cgf_adapter_transforms_total{status=\"success\"}[$__range])) / clamp_min(sum(increase(cgf_adapter_transforms_total[$__range])), 1)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.8,
                "color": "orange"
              },
              {
                "value": 0.95,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Mean Composite Reward (selected range)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(rate(cgf_reward_composite_sum[$__range])) / clamp_min(sum(rate(cgf_reward_composite_count[$__range])), 1)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.5,
                "color": "orange"
              },
              {
                "value": 0.75,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Spans Collected/min by Kind",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum by (span_kind) (rate(cgf_spans_collected_total[5m])) * 60",
          "legendFormat": "{{span_kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 11,
      "title": "Spans Exported/min by Exporter",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum by (exporter) (rate(cgf_spans_exported_total[5m])) * 60",
          "legendFormat": "{{exporter}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Optimization Quality",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "collapsed": false
    },
    {
      "id": 20,
      "title": "Composite Reward Distribution by Resource Type",
      "type": "heatmap",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(cgf_reward_composite_bucket[5m]))",
          "legendFormat": "{{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ],
      "options": {
        "yAxis": {
          "unit": "short"
        },
        "calculate": false
      }
    },
    {
      "id": 21,
      "title": "Feedback Dimensions (current)",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "targets": [
        {
          "expr": "avg by (resource_type, dimension) (cgf_feedback_dimensions)",
          "legendFormat": "{{resource_type}} / {{dimension}}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "decimals": 3
        }
      }
    },
    {
      "id": 22,
      "title": "Adapter Transforms by Resource Type & Status",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "expr": "sum by (resource_type, status) (rate(cgf_adapter_transforms_total[5m])) * 60",
          "legendFormat": "{{resource_type}} \u2014 {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Future (Stage 3 Eval Harness)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "collapsed": true,
      "panels": [
        {
          "id": 30,
          "title": "Phase Transitions / Eval Scores (placeholder)",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 24,
            "x": 0,
            "y": 31
          },
          "description": "Placeholder \u2014 populated when Stage 3 (eval harness) lands. Will track CGF phase transitions (PLANNING \u2192 RESEARCH \u2192 DESIGN \u2192 GENERATE \u2192 ITERATE \u2192 VALIDATE) and per-iteration eval scores.",
          "targets": [
            {
              "expr": "vector(0)",
              "legendFormat": "no data yet",
              "refId": "A"
            }
          ]
        }
      ]
    }
  ]
}
