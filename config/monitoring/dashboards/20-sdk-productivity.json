    {
      "id": 20310,
      "type": "timeseries",
      "title": "Tool Calls (harness-side, by tool_name)",
      "description": "From harness_tool_calls_total \u2014 populated by interactive.py. Autonomous + CGF runs don't currently emit harness-side tool metrics, so multi-mode coverage relies on the SDK-side code_edit_tool_decision (Dashboard 40).",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (tool_name) (rate(harness_tool_calls_total[5m])) * 60",
          "legendFormat": "{{tool_name}}",
