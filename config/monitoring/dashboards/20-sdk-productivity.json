  "panels": [
    {
      "id": 20100,
      "type": "stat",
      "title": "Active Sessions",
      "description": "Currently active sessions across all agents (harness-side gauge).",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(harness_agent_active_sessions)",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text-primary"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 20110,
      "type": "stat",
      "title": "Sessions Started (selected range)",
      "description": "Total session-start events in the dashboard time window.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_session_count_total[$__range]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text-primary"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 20120,
      "type": "stat",
      "title": "Net Lines of Code (selected range)",
      "description": "Added \u2212 Removed lines via `sum_over_time` (NOT `increase` \u2014 these are delta-style counters; `increase` extrapolates them to nonsense values, per spec \u00a7 2 gotcha #3).",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(sum_over_time(claude_code_lines_of_code_count_total{type=\"added\"}[$__range])) - sum(sum_over_time(claude_code_lines_of_code_count_total{type=\"removed\"}[$__range]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text-primary"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 20130,
      "type": "stat",
      "title": "Productivity Multiplier (cli / user)",
      "description": "CAVEAT: active_time{type=\"user\"} was never observed in 24h on harness workloads \u2014 likely interactive-only. This stat will show as Inf or '\u2014' until interactive sessions populate the denominator. See OBSERVABILITY.md \u00a7 6 item 8. Treat as directional, never a performance KPI \u2014 Mike Lane reports >10,000\u00d7 ratios with parallel agents.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_active_time_seconds_total{type=\"cli\"}[$__range])) / sum(rate(claude_code_active_time_seconds_total{type=\"user\"}[$__range]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text-primary"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "id": 20200,
      "type": "timeseries",
      "title": "Sessions Started by start_type",
      "description": "fresh / resume / continue. Time-series per session-start kind.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (start_type) (rate(claude_code_session_count_total[5m])) * 300",
          "legendFormat": "{{start_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "custom": {
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      }
    },
    {
      "id": 20210,
      "type": "timeseries",
      "title": "Lines of Code Added / Removed",
      "description": "Using `sum_over_time` not `increase` \u2014 these are delta counters. Mike Lane's gist explicitly warns about the `increase()` extrapolation pitfall.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(sum_over_time(claude_code_lines_of_code_count_total{type=\"added\"}[5m]))",
          "legendFormat": "added",
          "refId": "A"
        },
        {
          "expr": "-sum(sum_over_time(claude_code_lines_of_code_count_total{type=\"removed\"}[5m]))",
          "legendFormat": "removed",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "custom": {
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      }
    },
    {
      "id": 20300,
      "type": "timeseries",
      "title": "Active Time \u2014 CLI vs User",
      "description": "CAVEAT: type=\"user\" is interactive-only on current harness workloads; the line will sit at zero for non-interactive runs.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (type) (rate(claude_code_active_time_seconds_total[5m]))",
