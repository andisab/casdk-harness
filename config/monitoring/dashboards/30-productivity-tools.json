                  "text": "—",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 20120,
      "type": "stat",
      "title": "Net Lines of Code (selected range)",
      "description": "Added − Removed lines via `sum_over_time` (NOT `increase` — these are delta-style counters; `increase` extrapolates them to nonsense values, per spec § 2 gotcha #3).",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(sum_over_time(claude_code_lines_of_code_count_total{type=\"added\"}[$__range])) - sum(sum_over_time(claude_code_lines_of_code_count_total{type=\"removed\"}[$__range]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#A0A0A0"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "—",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 40100,
      "type": "stat",
      "title": "Edit Acceptance Rate (Overall)",
      "description": "accept / (accept + reject) across all code-edit tools. NOTE: SDK metric name is claude_code_code_edit_tool_decision_total (NOT _count_total as upstream spec lists). See OBSERVABILITY.md § 6 item 4.",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_code_edit_tool_decision_total{decision=\"accept\"}[$__range])) / sum(rate(claude_code_code_edit_tool_decision_total[$__range]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#A0A0A0"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "—",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "percentunit",
          "decimals": 2
