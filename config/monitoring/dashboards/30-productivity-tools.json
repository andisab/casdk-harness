    {
      "id": 20130,
      "type": "stat",
      "title": "Productivity Multiplier (cli / user)",
      "description": "CAVEAT: active_time{type=\"user\"} was never observed in 24h on harness workloads — likely interactive-only. This stat will show as Inf or '—' until interactive sessions populate the denominator. See OBSERVABILITY.md § 6 item 8. Treat as directional, never a performance KPI — Mike Lane reports >10,000× ratios with parallel agents.",
      "gridPos": {
        "x": 16,
        "y": 20,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
