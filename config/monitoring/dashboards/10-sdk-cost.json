  "panels": [
    {
      "id": 10100,
      "type": "stat",
      "title": "Spend Rate ($/hour)",
      "description": "Current cost rate normalized to per-hour from a 5m window.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_cost_usage_USD_total[5m])) * 3600",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10110,
      "type": "stat",
      "title": "Spend (selected range)",
      "description": "Total spend across the dashboard time window.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "none",
        "colorMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text-primary"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 10120,
      "type": "stat",
      "title": "Cost / Accepted Edit",
      "description": "Average cost per accepted code edit, computed as total spend \u00f7 total accepted edits across the dashboard range. A defensible efficiency KPI; rising values point to too much Opus where Sonnet would suffice, or over-high `effort` settings.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range])) / sum(increase(claude_code_code_edit_tool_decision_total{decision=\"accept\"}[$__range]))",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text-primary"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "currencyUSD",
          "decimals": 3
        },
        "overrides": []
      }
    },
    {
      "id": 10130,
      "type": "stat",
      "title": "Projected Monthly Spend",
      "description": "Linear extrapolation from the last 7 days of spend, projected 30 days ahead. Treat as directional, not a forecast \u2014 Anthropic has re-priced Opus downward 3\u00d7 within a year.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "predict_linear(claude_code_cost_usage_USD_total[7d], 30*86400)",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text-primary"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "currencyUSD",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 10200,
      "type": "timeseries",
      "title": "Spend by Model",
      "description": "Per-model cost rate. Inspect for mid-session model switches.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(claude_code_cost_usage_USD_total{model=~\"$model\"}[5m])) * 3600",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "\u2014",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "currencyUSD",
          "custom": {
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "decimals": 2
        },
        "overrides": []
      }
    },
