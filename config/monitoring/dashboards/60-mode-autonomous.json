    {
      "id": 65130,
      "type": "stat",
      "title": "Completion %",
      "description": "Completed / total. Denominator includes pending + failed. Reaches 100% when every task is either PASS or FAIL.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(harness_task_progress{status=\"completed\"}) / clamp_min(sum(harness_task_progress), 1)",
          "refId": "A",
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "graphMode": "area",
