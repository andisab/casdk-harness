    {
      "id": 65200,
      "type": "timeseries",
      "title": "Commits Over Time",
      "description": "Per-5min commit count via sum_over_time (NOT increase — spec § 2 gotcha #3). CAVEAT: claude_code_commit_count_total was empty in 24h on typical CGF-optimization workloads (see OBSERVABILITY.md § 6 item 7). Will populate when Claude commits in-session during autonomous mode.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(sum_over_time(claude_code_commit_count_total[5m]))",
          "legendFormat": "commits / 5min",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null+nan",
                "result": {
                  "text": "—",
                  "color": "text-secondary"
                }
              }
            }
          ],
          "unit": "none",
          "custom": {
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      }
    },
    {
      "id": 65210,
      "type": "timeseries",
      "title": "Lines of Code (added vs removed, 5m windows)",
      "description": "Per-5min LoC delta. Uses sum_over_time per the delta-counter gotcha. Removed shown as negative for visual stacking.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(sum_over_time(claude_code_lines_of_code_count_total{type=\"added\"}[5m]))",
          "legendFormat": "added",
          "refId": "A"
        },
        {
          "expr": "-sum(sum_over_time(claude_code_lines_of_code_count_total{type=\"removed\"}[5m]))",
          "legendFormat": "removed",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
