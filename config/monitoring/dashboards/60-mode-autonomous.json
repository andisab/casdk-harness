    {
      "id": 65300,
      "type": "timeseries",
      "title": "Agent Duration P50 / P95 by Agent",
      "description": "Per-cycle agent execution duration from harness_agent_duration_seconds_bucket. Autonomous mode runs the main agent in a loop; this surfaces cycle-by-cycle latency.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (agent, le) (rate(harness_agent_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{agent}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (agent, le) (rate(harness_agent_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{agent}}",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
