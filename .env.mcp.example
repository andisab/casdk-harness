# =============================================================================
# MCP Server API Keys
# =============================================================================
# Copy this file to .env.mcp and fill in your values.
# This file is loaded automatically by docker-compose.yml via the env_file directive.
# Add new MCP server credentials here without modifying docker-compose.yml.

# GitHub MCP Server (Tier 1)
# Required for GitHub operations (repos, issues, PRs)
# Get token at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# GitLab MCP Server (Tier 1)
# Required for GitLab operations (projects, issues, MRs)
# Get token at: https://gitlab.com/-/user_settings/personal_access_tokens
# Scopes: api, read_user, read_repository, write_repository
GITLAB_PERSONAL_ACCESS_TOKEN=glpat-your_token_here

# Joplin MCP Server (Tier 2)
# Required for note-taking and documentation integration
# Get token from Joplin: Tools > Options > Web Clipper > Advanced options
JOPLIN_API_TOKEN=your_joplin_token_here
JOPLIN_BASE_URL=http://localhost:41184
